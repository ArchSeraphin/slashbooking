includes:
  - vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
  level: 8
  paths:
    - src
  bootstrapFiles:
    - tests/bootstrap.php
  scanFiles:
    - tests/stubs/wp-cli.stub.php
  reportUnmatchedIgnoredErrors: false
  # Google SDK phpdoc types are imprecise (e.g. getStart() typed non-null but can return null).
  # Without this flag, PHPStan 2.x flags our defensive null checks as redundant.
  treatPhpDocTypesAsCertain: false
  ignoreErrors:
    # $wpdb->prepare wants literal-string; we always concatenate $wpdb->prefix
    # because table names cannot be parameterized. The prefix is trusted.
    -
      identifier: argument.type
      paths:
        - src/Persistence/*
        - src/Activator.php
    # WordPress stubs sometimes lack precise types; we tighten via PHPDoc.
